{
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    { "path": "/api/cron/heartbeat", "schedule": "* * * * *" }
  ],
  "functions": {
    "app/api/webhook/telegram/route.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/zeroclaw/dist/bin/**"
    },
    "app/api/cron/heartbeat/route.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/zeroclaw/dist/bin/**"
    }
  }
}
