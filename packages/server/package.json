{
  "name": "@clawrun/server",
  "version": "0.1.2",
  "description": "Next.js server package for ClawRun",
  "license": "Apache-2.0",
  "author": "Afshin Mehrabani",
  "homepage": "https://clawrun.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawrun-sh/clawrun.git",
    "directory": "packages/server"
  },
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist .next",
    "dev": "next dev",
    "build": "tsc -p tsconfig.lib.json && next build",
    "start": "next start",
    "lint": "eslint lib",
    "format:check": "prettier --check lib"
  },
  "exports": {
    "./api/health": {
      "types": "./dist/handlers/health.d.ts",
      "default": "./dist/handlers/health.js"
    },
    "./api/webhook-wake": {
      "types": "./dist/handlers/webhook-wake.d.ts",
      "default": "./dist/handlers/webhook-wake.js"
    },
    "./api/heartbeat": {
      "types": "./dist/handlers/heartbeat.d.ts",
      "default": "./dist/handlers/heartbeat.js"
    },
    "./api/sandbox-heartbeat": {
      "types": "./dist/handlers/sandbox-heartbeat.d.ts",
      "default": "./dist/handlers/sandbox-heartbeat.js"
    },
    "./api/sandbox-restart": {
      "types": "./dist/handlers/sandbox-restart.d.ts",
      "default": "./dist/handlers/sandbox-restart.js"
    },
    "./api/sandbox-start": {
      "types": "./dist/handlers/sandbox-start.d.ts",
      "default": "./dist/handlers/sandbox-start.js"
    },
    "./api/sandbox-stop": {
      "types": "./dist/handlers/sandbox-stop.d.ts",
      "default": "./dist/handlers/sandbox-stop.js"
    },
    "./api/accept": {
      "types": "./dist/handlers/accept.d.ts",
      "default": "./dist/handlers/accept.js"
    },
    "./api/chat": {
      "types": "./dist/handlers/chat.d.ts",
      "default": "./dist/handlers/chat.js"
    },
    "./pages/home": {
      "types": "./dist/components/home.d.ts",
      "default": "./dist/components/home.js"
    },
    "./pages/layout": {
      "types": "./dist/components/root-layout.d.ts",
      "default": "./dist/components/root-layout.js"
    },
    "./pages/chat": {
      "types": "./dist/components/chat-page-server.d.ts",
      "default": "./dist/components/chat-page-server.js"
    },
    "./pages/expired": {
      "types": "./dist/components/expired-page.d.ts",
      "default": "./dist/components/expired-page.js"
    },
    "./proxy": {
      "types": "./dist/auth/middleware.d.ts",
      "default": "./dist/auth/middleware.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "default": "./dist/setup.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "package.json"
  ],
  "dependencies": {
    "@clawrun/agent": "workspace:*",
    "@clawrun/channel": "workspace:*",
    "@clawrun/logger": "workspace:*",
    "@clawrun/provider": "workspace:*",
    "@clawrun/runtime": "workspace:*",
    "ai": "^6.0.0",
    "@ai-sdk/react": "^3.0.0",
    "next": "^16.0.0",
    "@clawrun/auth": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@clawrun/ui": "workspace:*",
    "lucide-react": "^0.500.0",
    "next-themes": "^0.4.0",
    "shadcn": "^3.8.5",
    "streamdown": "^2.3.0",
    "dexie": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "@tailwindcss/postcss": "^4.0.0"
  },
  "devDependencies": {
    "@clawrun/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
