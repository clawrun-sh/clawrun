{
  "name": "clawrun",
  "version": "0.1.4",
  "description": "CLI for deploying ClawRun AI agent hosting",
  "license": "Apache-2.0",
  "author": "Afshin Mehrabani",
  "homepage": "https://clawrun.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawrun-sh/clawrun.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "clawrun": "./dist/cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "format:check": "prettier --check src",
    "format": "prettier --write src"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@clawrun/agent": "workspace:*",
    "@clawrun/agent-zeroclaw": "workspace:*",
    "@clawrun/channel": "workspace:*",
    "@clawrun/logger": "workspace:*",
    "@clawrun/provider": "workspace:*",
    "@clawrun/provider-vercel": "workspace:*",
    "@clawrun/runtime": "workspace:*",
    "@clawrun/sdk": "workspace:*",
    "@clawrun/server": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "@mariozechner/pi-tui": "^0.57.1",
    "chalk": "^5.4.0",
    "cli-highlight": "^2.1.11",
    "cmd-ts": "^0.15.0",
    "execa": "^9.5.0",
    "human-id": "^4.1.1",
    "qrcode-terminal": "^0.12.0",
    "sandbox": "^2.5.5",
    "zeroclaw": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clawrun/tsconfig": "workspace:*",
    "@types/iarna__toml": "^2.0.5",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "agent",
    "deploy",
    "cli",
    "sandbox",
    "microvm",
    "ai-agent",
    "clawrun"
  ]
}
