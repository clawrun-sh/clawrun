  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.scripts.json && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@clawrun/agent": "workspace:*",
    "@clawrun/logger": "workspace:*",
    "@clawrun/provider": "workspace:*",
    "@neondatabase/serverless": "^0.10.0",
    "@upstash/redis": "^1.34.0",
    "drizzle-orm": "^0.38.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clawrun/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
