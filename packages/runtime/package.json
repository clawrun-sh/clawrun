{
  "name": "@clawrun/runtime",
  "version": "0.1.6",
  "description": "Sandbox runtime and orchestration for ClawRun",
  "license": "Apache-2.0",
  "author": "Afshin Mehrabani",
  "homepage": "https://clawrun.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawrun-sh/clawrun.git",
    "directory": "packages/runtime"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "node build-sidecar.mjs && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "format:check": "prettier --check src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@clawrun/agent": "workspace:*",
    "@clawrun/logger": "workspace:*",
    "@clawrun/provider": "workspace:*",
    "ioredis": "^5.6.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clawrun/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "runtime",
    "sandbox",
    "lifecycle",
    "sidecar",
    "clawrun"
  ]
}
