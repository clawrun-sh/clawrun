{
  "name": "@clawrun/runtime",
  "version": "0.1.0",
  "description": "Sandbox runtime and orchestration for ClawRun",
  "license": "Apache-2.0",
  "author": "Afshin Mehrabani",
  "homepage": "https://clawrun.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawrun-sh/clawrun.git",
    "directory": "packages/runtime"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
