{
  "name": "zeroclaw-napi",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "zeroclaw-napi",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build:bin": "bash build-docker.sh",
    "build": "echo 'zeroclaw-napi: native artifacts built by build:bin'",
    "build:debug": "napi build --platform"
  },
  "optionalDependencies": {
    "zeroclaw-napi-darwin-arm64": "workspace:*",
    "zeroclaw-napi-darwin-x64": "workspace:*",
    "zeroclaw-napi-linux-x64-gnu": "workspace:*",
    "zeroclaw-napi-linux-arm64-gnu": "workspace:*"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
