{
  "name": "zeroclaw",
  "version": "0.1.2",
  "description": "TypeScript/JavaScript wrapper for the ZeroClaw AI agent",
  "license": "Apache-2.0",
  "author": "Afshin Mehrabani",
  "homepage": "https://clawrun.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawrun-sh/clawrun.git",
    "directory": "packages/zeroclaw"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:bin": "bash build-docker.sh",
    "generate:types": "bash scripts/generate-types.sh",
    "clean": "rm -rf dist",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "format:check": "prettier --check --ignore-path ../../.prettierignore src",
    "format": "prettier --write --ignore-path ../../.prettierignore src"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clawrun/tsconfig": "workspace:*",
    "@types/iarna__toml": "^2.0.5",
    "@types/node": "^22.0.0",
    "json-schema-to-typescript": "^15.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
