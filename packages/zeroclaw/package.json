{
  "name": "zeroclaw",
  "version": "0.1.2",
  "description": "TypeScript/JavaScript wrapper for the ZeroClaw AI agent",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:bin": "bash build-docker.sh",
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5"
  },
  "devDependencies": {
    "@cloudclaw/tsconfig": "workspace:*",
    "@types/iarna__toml": "^2.0.5",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
