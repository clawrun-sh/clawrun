{
  "name": "@clawrun/logger",
  "version": "0.1.0",
  "description": "Structured logging for ClawRun",
  "license": "Apache-2.0",
  "author": "Afshin Mehrabani",
  "homepage": "https://clawrun.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawrun-sh/clawrun.git",
    "directory": "packages/logger"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "format:check": "prettier --check --ignore-path ../../.prettierignore src",
    "format": "prettier --write --ignore-path ../../.prettierignore src"
  },
  "dependencies": {
    "consola": "^3.4.0"
  },
  "devDependencies": {
    "@clawrun/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
