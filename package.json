{
  "name": "clawrun-workspace",
  "private": true,
  "license": "Apache-2.0",
  "author": "Afshin Mehrabani",
  "homepage": "https://clawrun.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawrun-sh/clawrun.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "clean": "turbo run clean",
    "build": "turbo run build",
    "rebuild": "turbo run clean && turbo run build --force",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format:check": "turbo run format:check",
    "format": "turbo run format",
    "test": "turbo run test",
    "clawrun": "node packages/cli/dist/cli.js",
    "website:dev": "turbo run dev --filter @clawrun/website",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
