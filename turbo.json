{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build:bin": {
      "inputs": [
        "upstream/**",
        "build-docker.sh",
        "Dockerfile",
        "Cargo.toml"
      ],
      "outputs": ["dist/bin/**", "npm/**/*.node", "index.js", "index.d.ts"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "!dist/bin/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
