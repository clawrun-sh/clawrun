{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "clean": {
      "cache": false
    },
    "build:bin": {
      "inputs": ["upstream/**", "build-docker.sh", "Dockerfile", "Cargo.toml"],
      "outputs": ["dist/bin/**", "npm/**/*.node", "index.js", "index.d.ts", "src/zeroclaw-config.schema.json"]
    },
    "zeroclaw#generate:types": {
      "dependsOn": ["build:bin"],
      "inputs": ["src/zeroclaw-config.schema.json", "scripts/generate-types.sh"],
      "outputs": ["src/generated/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "!dist/bin/**", ".next/**"]
    },
    "@clawrun/ui#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "zeroclaw#build": {
      "dependsOn": ["^build", "build:bin", "generate:types"],
      "outputs": ["dist/**", "!dist/bin/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "format": {
      "outputs": []
    }
  }
}
